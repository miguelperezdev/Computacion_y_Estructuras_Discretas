# samples/secure.env
# Secure configuration — sensitive keys use environment variable references

APP_NAME=chomsky
APP_PORT=8080
DB_HOST=localhost
DB_NAME=mydb
DB_PASSWORD=${SECURE_DB_PASSWORD}
SECRET_KEY=${APP_SECRET_KEY}
API_KEY=${EXTERNAL_API_KEY}
AUTH_TOKEN=${APP_AUTH_TOKEN}
LOG_LEVEL=info
DEBUG=false
