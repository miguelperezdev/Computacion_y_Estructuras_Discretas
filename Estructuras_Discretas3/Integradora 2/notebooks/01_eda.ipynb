   "outputs": [
    {
     "data": {
      "image/png": "",
      "text/plain": [
       "<Figure size 1400x500 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    }
   ],
   "source": [
    "from collections import Counter\n",
    "\n",
    "def top_words(df, label, n=20):\n",
    "    text = ' '.join(df[df['label'] == label]['clean_sentence'].dropna())\n",
    "    return Counter(text.split()).most_common(n)\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "for ax, label, color in zip(axes, [0, 1], ['#F44336', '#2196F3']):\n",
    "    words, counts = zip(*top_words(df, label))\n",
    "    ax.barh(words[::-1], counts[::-1], color=color, edgecolor='white')\n",
    "    title = 'Negative' if label == 0 else 'Positive'\n",
    "    ax.set_title(f'Top 20 Words — {title}', fontsize=12)\n",
    "    ax.set_xlabel('Frequency')\n",
    "\n",
    "plt.suptitle('Most Frequent Words by Sentiment', fontsize=14, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig(f'{FIGURES_DIR}/01_top_words.png', dpi=150, bbox_inches='tight')\n",
    "plt.show()"
   ]
  },
