    "import sys\n",
    "import os\n",
    "sys.path.append(os.path.join(os.path.dirname(os.path.abspath('__file__')), '..'))\n",
    "\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import json\n",
    "\n",
    "from sklearn.dummy import DummyClassifier\n",
    "from sklearn.model_selection import train_test_split\n",
    "\n",
    "from src.preprocessing import load_raw_data, preprocess_dataframe\n",
    "from src.evaluate import compute_metrics\n",
    "from src.visualize import plot_confusion_matrix\n",
    "\n",
    "FIGURES_DIR = '../outputs/figures'\n",
    "METRICS_DIR = '../outputs/metrics'\n",
    "os.makedirs(FIGURES_DIR, exist_ok=True)\n",
    "os.makedirs(METRICS_DIR, exist_ok=True)\n",
    "\n",
    "RANDOM_STATE = 42\n",
    "print('Setup complete.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. Load and Prepare Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-06-09T16:21:33.030884Z",
     "iopub.status.busy": "2026-06-09T16:21:33.030668Z",
     "iopub.status.idle": "2026-06-09T16:21:33.092637Z",
     "shell.execute_reply": "2026-06-09T16:21:33.092144Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Train: 2198 | Test: 550\n",
      "Train class balance: [1089 1109]\n",
      "Test  class balance: [273 277]\n"
     ]
    }
   ],
   "source": [
    "df = preprocess_dataframe(load_raw_data('../data'))\n",
    "X = df['clean_sentence'].values\n",
    "y = df['label'].values\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y, test_size=0.2, stratify=y, random_state=RANDOM_STATE\n",
    ")\n",
    "print(f'Train: {len(X_train)} | Test: {len(X_test)}')\n",
    "print(f'Train class balance: {np.bincount(y_train)}')\n",
    "print(f'Test  class balance: {np.bincount(y_test)}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. DummyClassifier — Strategies\n",
    "\n",
    "We test three strategies to understand the baseline ceiling:\n",
    "- **most_frequent**: always predicts the majority class\n",
    "- **stratified**: randomly predicts labels respecting class distribution\n",
    "- **uniform**: randomly predicts with equal probability"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "metadata": {
    "execution": {
     "iopub.execute_input": "2026-06-09T16:21:33.093871Z",
     "iopub.status.busy": "2026-06-09T16:21:33.093785Z",
     "iopub.status.idle": "2026-06-09T16:21:33.107569Z",
     "shell.execute_reply": "2026-06-09T16:21:33.107129Z"
    }
   },
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "[most_frequent] Accuracy=0.5036 | F1=0.6699 | Kappa=0.0000\n",
      "[stratified] Accuracy=0.4909 | F1=0.4815 | Kappa=-0.0179\n",
      "[uniform] Accuracy=0.5255 | F1=0.5331 | Kappa=0.0507\n"
     ]
    }
   ],
   "source": [
    "strategies = ['most_frequent', 'stratified', 'uniform']\n",
    "all_results = []\n",
    "\n",
    "for strategy in strategies:\n",
    "    clf = DummyClassifier(strategy=strategy, random_state=RANDOM_STATE)\n",
    "    clf.fit(X_train, y_train)\n",
    "    y_pred = clf.predict(X_test)\n",
    "    metrics = compute_metrics(y_test, y_pred, model_name=f'Dummy ({strategy})')\n",
    "    all_results.append(metrics)\n",
    "    print(f\"[{strategy}] Accuracy={metrics['accuracy']:.4f} | F1={metrics['f1_score']:.4f} | Kappa={metrics['cohen_kappa']:.4f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
